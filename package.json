{
  "name": "ai-recruiter-pro",
  "version": "1.0.0",
  "description": "AI-Powered Intelligent Recruiting Platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "node dev-server.js",
    "dev-full": "concurrently \"cd backend && npm start\" \"node dev-server.js\"",
    "install-all": "npm install && cd backend && npm install",
    "build": "cd backend && npm install",
    "serve": "node dev-server.js"
  },
  "keywords": [
    "recruitment",
    "AI",
    "matching",
    "hiring",
    "job-seeker"
  ],
  "author": "Kulwanth Kotagiri",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^8.0.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
